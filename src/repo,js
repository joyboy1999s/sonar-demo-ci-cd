  // Get complete repository tree with commit hashes (similar to GitHub/GitLab flow)
  private async getRepositoryTreeWithHashes(
    owner: string,
    repo: string,
    token: string,
    branch: string
  ): Promise<BitbucketTreeItem[]> {
    const allItems: BitbucketTreeItem[] = [];

    // Recursively fetch all files and directories
    await this.fetchDirectoryRecursively(owner, repo, token, branch, '', allItems);

    return allItems;
  }

  // Recursively fetch directory contents and get file metadata
  private async fetchDirectoryRecursively(
    owner: string,
    repo: string,
    token: string,
    branch: string,
    path: string,
    allItems: BitbucketTreeItem[]
  ): Promise<void> {
    try {
      // Get directory contents
      const dirUrl = `https://api.bitbucket.org/2.0/repositories/${owner}/${repo}/src/${branch}/${path}`;
      const dirResponse = await fetch(dirUrl, {
        headers: {
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json'
        }
      });

      if (!dirResponse.ok) {
        console.warn(`Bitbucket: Failed to fetch directory ${path}: ${dirResponse.status}`);
        return;
      }

      const dirData = await dirResponse.json() as BitbucketTreeResponse;
      const items = dirData.values || [];

      for (const item of items) {
        if (item.type === 'commit_file') {
          // For files, get metadata to get commit hash
          try {
            const fileMetaUrl = `https://api.bitbucket.org/2.0/repositories/${owner}/${repo}/src/${branch}/${item.path}?format=meta`;
            const fileResponse = await fetch(fileMetaUrl, {
              headers: {
                'Authorization': `Bearer ${token}`,
                'Content-Type': 'application/json'
              }
            });

            if (fileResponse.ok) {
              const fileMeta = await fileResponse.json() as BitbucketTreeItem;
              allItems.push(fileMeta); // Use metadata version with commit hash
            } else {
              console.warn(`Bitbucket: Failed to fetch file metadata ${item.path}: ${fileResponse.status}`);
              allItems.push(item); // Fallback to original item
            }
          } catch (error: any) {
            console.warn(`Bitbucket: Error fetching file metadata ${item.path}:`, error.message);
            allItems.push(item); // Fallback to original item
          }
        } else if (item.type === 'commit_directory') {
          // Add directory to the list first
          allItems.push(item);

          // Then recursively fetch its contents
          await this.fetchDirectoryRecursively(owner, repo, token, branch, item.path, allItems);
        }
      }
    } catch (error: any) {
      console.warn(`Bitbucket: Error fetching directory ${path}:`, error.message);
    }
  }

  private buildBitbucketNestedTree(flatTree: BitbucketTreeItem[]): FileTreeNode[] {
    const pathMap: Record<string, FileTreeNode[]> = {};

    // Group items by their parent directory
    for (const item of flatTree) {
      const parts = item.path.split('/');
      const fileName = parts.pop()!;
      const parentDir = parts.join('/');

      if (!pathMap[parentDir]) {
        pathMap[parentDir] = [];
      }

      if (item.type === 'commit_file') {
        const fileNode: FileTreeNode = {
          type: 'file' as const,
          name: fileName,
          path: item.path,
          sha: item.commit?.hash  // Use commit hash as SHA for change detection
        };
        pathMap[parentDir].push(fileNode);
      } else if (item.type === 'commit_directory') {
        const folderNode: FileTreeNode = {
          type: 'folder' as const,
          name: fileName,
          path: item.path,
          children: []
        };
        pathMap[parentDir].push(folderNode);
      }
    }

    // Recursively build the tree structure
    const buildTree = (basePath: string): FileTreeNode[] => {
      const items = pathMap[basePath] || [];

      // Sort items: folders first, then files, alphabetically within each type
      items.sort((a, b) => {
        if (a.type === b.type) {
          return a.name.localeCompare(b.name);
        }
        return a.type === 'folder' ? -1 : 1;
      });

      return items.map(item => {
        if (item.type === 'folder') {
          const newPath = basePath ? `${basePath}/${item.name}` : item.name;
          item.children = buildTree(newPath);
        }
        return item;
      });
    };

    return buildTree('');
  }

  async getRepositoryList(token: string, page: number = 1, perPage: number = 30): Promise<{
    repositories?: any[];
    error?: boolean;
    message?: string;
    hasMore?: boolean;
    tokenExpiryDate?: Date;
  }> {
    try {
      const response = await fetch(`https://api.bitbucket.org/2.0/repositories?role=member&page=${page}&pagelen=${perPage}&sort=-updated_on`, {
        headers: {
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json'
        }
      });

      if (!response.ok) {
        if (response.status === 401) {
          return {
            error: true,
            message: "401 Unauthorized - Invalid or expired Bitbucket token",
          };
        }
        if (response.status === 403) {
          return {
            error: true,
            message: "403 Forbidden - Token doesn't have permission to access repositories",
          };
        }
        throw new Error(`Bitbucket API error: ${response.status} ${response.statusText}`);
      }

      const data = await response.json() as any;
      const repositories = data.values || [];
      const hasMore = Boolean(data.next);

      const formattedRepositories = repositories.map((repo: any) => ({
        id: repo.uuid,
        name: repo.name,
        full_name: repo.full_name,
        description: repo.description,
        visibility: repo.is_private ? 'private' : 'public',
        default_branch: repo.mainbranch?.name || 'main',
        html_url: repo.links?.html?.href,
        owner: {
          login: repo.owner?.display_name || repo.owner?.username,
          avatar_url: repo.owner?.links?.avatar?.href,
        },
        updated_at: repo.updated_on,
        created_at: repo.created_on,
        language: repo.language,
        stargazers_count: 0, // Bitbucket doesn't have stars
        forks_count: 0 // Bitbucket doesn't have forks count in this endpoint
      }));

      return {
        repositories: formattedRepositories,
        hasMore,
        tokenExpiryDate: undefined // Bitbucket doesn't provide token expiry in headers
      };
    } catch (err: any) {
      console.error("Failed to fetch Bitbucket repositories:", err.message || err);

      if (err.message?.includes('NetworkError') || err.message?.includes('fetch')) {
        return {
          error: true,
          message: "Network error - Unable to connect to Bitbucket API",
        };
      }

      return {
        error: true,
        message: err.message || "Unknown error fetching Bitbucket repositories",
      };
    }
  }

