// GitHub API response types
interface GitHubRepository {
  name: string;
  full_name: string;
  description: string | null;
  visibility: string;
  default_branch: string;
  html_url: string;
  owner: {
    login: string;
    avatar_url: string;
  };
}

interface GitHubCommit {
  commit: {
    tree: {
      sha: string;
    };
  };
}

interface GitHubTreeItem {
  path: string;
  type: 'blob' | 'tree';
  sha: string;
  size?: number;
  url: string;
}

interface GitHubTreeResponse {
  sha: string;
  url: string;
  tree: GitHubTreeItem[];
  truncated: boolean;
}

// GitLab API response types
interface GitLabTreeItem {
  id: string;
  name: string;
  type: 'tree' | 'blob';
  path: string;
  mode: string;
}

interface GitLabFileInfo {
  file_name: string;
  file_path: string;
  size: number;
  encoding: string;
  content: string;
  content_sha256: string;
  ref: string;
  blob_id: string;  // This is the actual SHA
  commit_id: string;
  last_commit_id: string;
}

// Bitbucket API response types
interface BitbucketTreeItem {
  path: string;
  type: 'commit_file' | 'commit_directory';
  size?: number;
  attributes?: any;
  commit?: {
    type: string;
    hash: string;
    links?: {
      self?: {
        href: string;
      };
      html?: {
        href: string;
      };
    };
  };
}

interface BitbucketTreeResponse {
  values: BitbucketTreeItem[];
  size: number;
  isLastPage: boolean;
  nextPageStart?: number;
}

// Represents a node in the file tree (file or folder)
export interface FileTreeNode {
  type: 'file' | 'folder';
  name: string;
  path: string;
  sha?: string;
  children?: FileTreeNode[];
}

// Generic interface for any Git provider
export interface GitProviderSyncInput {
  id?: any;
  owner?: any;
  repo?: any;
  default_branch?: any;
  token?: any;
  created_user_id?: any;
  provider?: any;
}

// Generic Git provider interface
export interface GitProvider {
  getRepositoryTree(owner: string, repo: string, token: string, default_branch: string): Promise<{
    repository?: any;
    tree?: FileTreeNode[];
    error?: boolean;
    message?: string;
  }>;
  getRepositoryList(token: string, page?: number, perPage?: number): Promise<{
    repositories?: any[];
    error?: boolean;
    message?: string;
    hasMore?: boolean;
    tokenExpiryDate?: Date;
  }>;
  getFileContent(owner: string, repo: string, path: string, token: string, branch: string): Promise<{
    content?: string;
    error?: boolean;
    message?: string;
  }>;
}

// GitHub-specific implementation
export class GitHubProvider implements GitProvider {
  private octokit: Octokit;

  constructor() {
    this.octokit = new Octokit();
  }

  async getRepositoryTree(owner: string, repo: string, token: string, default_branch: string): Promise<{
    repository?: any;
    tree?: FileTreeNode[];
    error?: boolean;
    message?: string;
  }> {
    try {
      this.octokit = new Octokit({ auth: token });

      const { data: repoMeta } = await this.octokit.request("GET /repos/{owner}/{repo}", {
        owner,
        repo,
      }) as { data: GitHubRepository };

      const { data: commitData } = await this.octokit.request(
        "GET /repos/{owner}/{repo}/commits/{ref}",
        {
          owner,
          repo,
          ref: default_branch,
        }
      ) as { data: GitHubCommit };

      const { data: treeData } = await this.octokit.request(
        "GET /repos/{owner}/{repo}/git/trees/{tree_sha}?recursive=1",
        {
          owner,
          repo,
          tree_sha: commitData.commit.tree.sha,
        }
      ) as { data: GitHubTreeResponse };

      const tree = this.buildGitHubNestedTree(treeData.tree);

      return {
        repository: {
          name: repoMeta.name,
          full_name: repoMeta.full_name,
          description: repoMeta.description,
          visibility: repoMeta.visibility,
          default_branch: default_branch,
          html_url: repoMeta.html_url,
          owner: {
            login: repoMeta.owner.login,
            avatar_url: repoMeta.owner.avatar_url,
          },
        },
        tree,
      };
    } catch (err: any) {
      console.error("Failed to fetch GitHub repository tree:", err.message || err);

      // Enhanced error handling with specific messages
      if (err.status === 401) {
        return {
          error: true,
          message: "401 Unauthorized - Invalid or expired GitHub token",
        };
      }

      if (err.status === 403) {
        return {
          error: true,
          message: "403 Forbidden - Token doesn't have permission to access this repository",
        };
      }

      if (err.status === 404) {
        return {
          error: true,
          message: "404 Not Found - Repository not found",
        };
      }

      if (err.status === 422) {
        return {
          error: true,
          message: "422 Unprocessable Entity - Invalid repository or owner name",
        };
      }

      if (err.status === 429) {
        return {
          error: true,
          message: "429 Rate limit exceeded - Too many requests to GitHub API",
        };
      }

      if (err.message?.includes('NetworkError') || err.message?.includes('fetch')) {
        return {
          error: true,
          message: "Network error - Unable to connect to GitHub API",
        };
      }

      return {
        error: true,
        message: err.message || "Unknown error fetching GitHub repository tree",
      };
    }
  }

  private buildGitHubNestedTree(flatTree: GitHubTreeItem[]): FileTreeNode[] {
    const pathMap: Record<string, any[]> = {};

    flatTree.forEach((item) => {
      const parts = item.path.split("/");
      const fileName = parts.pop()!;
      const parentDir = parts.join("/");

      if (!pathMap[parentDir]) pathMap[parentDir] = [];

      if (item.type === "blob") {
        pathMap[parentDir].push({
          type: "file",
          name: fileName,
          path: item.path,
          sha: item.sha,
        });
      } else if (item.type === "tree") {
        pathMap[parentDir].push({
          type: "folder",
          name: fileName,
          path: item.path,
          children: [],
        });
      }
    });

    const sortAndAttach = (basePath: string): FileTreeNode[] => {
      const isSpecial = (name: string) => /^[^a-zA-Z0-9]/.test(name);

      const sortedItems = (pathMap[basePath] || []).sort((a, b) => {
        const aSpecial = isSpecial(a.name);
        const bSpecial = isSpecial(b.name);
        if (a.type === b.type) {
          if (aSpecial && !bSpecial) return -1;
          if (!aSpecial && bSpecial) return 1;
          return a.name.localeCompare(b.name);
        }
        return a.type === "folder" ? -1 : 1;
      });

      return sortedItems.map((item) => {
        if (item.type === "folder") {
          const newPath = basePath ? `${basePath}/${item.name}` : item.name;
          item.children = sortAndAttach(newPath);
        }
        return item;
      });
    };

    return sortAndAttach("");
  }

  async getRepositoryList(token: string, page: number = 1, perPage: number = 30): Promise<{
    repositories?: any[];
    error?: boolean;
    message?: string;
    hasMore?: boolean;
    tokenExpiryDate?: Date;
  }> {
    try {
      this.octokit = new Octokit({ auth: token });

      const { data: repositories, headers } = await this.octokit.request("GET /user/repos", {
        page,
        per_page: perPage,
        sort: 'updated',
        direction: 'desc',
        type: 'all' // Get both public and private repos
      });
      const formattedRepositories = repositories.map((repo: any) => ({
        id: repo.id,
        name: repo.name,
        full_name: repo.full_name,
        description: repo.description,
        visibility: repo.private ? 'private' : 'public',
        default_branch: repo.default_branch,
        html_url: repo.html_url,
        owner: {
          login: repo.owner.login,
          avatar_url: repo.owner.avatar_url,
        },
        updated_at: repo.updated_at,
        created_at: repo.created_at,
        language: repo.language,
        stargazers_count: repo.stargazers_count,
        forks_count: repo.forks_count
      }));

      // Extract token expiry date from GitHub API response headers
      let tokenExpiryDate: Date | undefined;
      const tokenExpiryHeader = headers['github-authentication-token-expiration'];
      if (tokenExpiryHeader) {
        try {
          tokenExpiryDate = new Date(tokenExpiryHeader as string);
        } catch (error) {
          console.warn('Failed to parse GitHub token expiry date:', error);
        }
      }

      return {
        repositories: formattedRepositories,
        hasMore: repositories.length === perPage,
        tokenExpiryDate
      };
    } catch (err: any) {
      console.error("Failed to fetch GitHub repositories:", err.message || err);

      if (err.status === 401) {
        return {
          error: true,
          message: "401 Unauthorized - Invalid or expired GitHub token",
        };
      }

      if (err.status === 403) {
        return {
          error: true,
          message: "403 Forbidden - Token doesn't have permission to access repositories",
        };
      }

      if (err.status === 422) {
        return {
          error: true,
          message: "422 Unprocessable Entity - Invalid pagination parameters",
        };
      }

      if (err.status === 429) {
        return {
          error: true,
          message: "429 Rate limit exceeded - Too many requests to GitHub API",
        };
      }

      return {
        error: true,
        message: err.message || "Unknown error fetching GitHub repositories",
      };
    }
  }

  async getFileContent(owner: string, repo: string, path: string, token: string, branch: string): Promise<{
    content?: string;
    error?: boolean;
    message?: string;
  }> {
    try {
      this.octokit = new Octokit({ auth: token });
      const { data } = await this.octokit.request("GET /repos/{owner}/{repo}/contents/{path}", {
        owner,
        repo,
        path,
        ref: branch
      }) as { data: any };

      if (data.type === 'file' && data.content) {
        // GitHub returns base64 encoded content
        const content = Buffer.from(data.content, 'base64').toString('utf8');
        return { content };
      }

      return {
        error: true,
        message: "Path is not a file or has no content"
      };
    } catch (err: any) {
      console.error("Failed to fetch GitHub file content:", err.message || err);
      return {
        error: true,
        message: err.message || "Error fetching file content from GitHub"
      };
    }
  }
}

// GitLab-specific implementation
export class GitLabProvider implements GitProvider {
  async getRepositoryTree(owner: string, repo: string, token: string, default_branch: string): Promise<{
    repository?: any;
    tree?: FileTreeNode[];
    error?: boolean;
    message?: string;
  }> {
    try {
      // First, get the repository tree structure
      const treeResponse = await fetch(`https://gitlab.com/api/v4/projects/${encodeURIComponent(owner + '/' + repo)}/repository/tree?recursive=true&per_page=100&ref=${default_branch}`, {
        headers: {
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json'
        }
      });

      if (!treeResponse.ok) {
        const errorText = await treeResponse.text();
        console.error("GitLab API error response:", errorText);

        // Enhanced error handling with specific messages
        if (treeResponse.status === 401) {
          throw new Error("401 Unauthorized - Invalid or expired GitLab token");
        }

        if (treeResponse.status === 403) {
          throw new Error("403 Forbidden - Token doesn't have permission to access this repository");
        }

        if (treeResponse.status === 404) {
          throw new Error("404 Not Found - Repository not found");
        }

        if (treeResponse.status === 422) {
          throw new Error("422 Unprocessable Entity - Invalid repository or owner name");
        }

        if (treeResponse.status === 429) {
          throw new Error("429 Rate limit exceeded - Too many requests to GitLab API");
        }

        throw new Error(`GitLab API error: ${treeResponse.status} ${treeResponse.statusText}`);
      }

      const treeData = await treeResponse.json() as GitLabTreeItem[];
      console.log("GitLab tree data:", treeData);

      // Get SHA values for all files using the Files API
      const treeWithSHA = await this.enrichTreeWithSHA(owner, repo, token, default_branch, treeData);
      console.log("GitLab tree with SHA:", treeWithSHA);

      const tree = this.buildGitLabNestedTree(treeWithSHA);
      console.log("GitLab nested tree:", tree);

      return {
        repository: {
          name: repo,
          full_name: `${owner}/${repo}`,
          default_branch: default_branch,
        },
        tree,
      };
    } catch (err: any) {
      console.error("Failed to fetch GitLab repository tree:", err.message || err);

      // Enhanced error handling with specific messages
      if (err.message?.includes('NetworkError') || err.message?.includes('fetch')) {
        return {
          error: true,
          message: "Network error - Unable to connect to GitLab API",
        };
      }

      if (err.message?.includes('JSON')) {
        return {
          error: true,
          message: "Invalid response from GitLab API",
        };
      }

      return {
        error: true,
        message: err.message || "Unknown error fetching GitLab repository tree",
      };
    }
  }

  // Helper method to enrich tree data with SHA values
  private async enrichTreeWithSHA(
    owner: string,
    repo: string,
    token: string,
    default_branch: string,
    treeData: GitLabTreeItem[]
  ): Promise<Array<GitLabTreeItem & { sha?: string }>> {
    const enrichedTree: Array<GitLabTreeItem & { sha?: string }> = [];

    // Separate files and directories
    const fileItems = treeData.filter(item => item.type === 'blob');
    const directoryItems = treeData.filter(item => item.type === 'tree');

    // Add directories first (they don't need SHA values)
    enrichedTree.push(...directoryItems.map(item => ({ ...item, sha: undefined })));

    // If no files, return early
    if (fileItems.length === 0) {
      return enrichedTree;
    }

    console.log(`GitLab: Fetching SHA values for ${fileItems.length} files...`);

    // Process files in batches to avoid overwhelming the API
    const batchSize = 5; // Reduced batch size for better reliability
    let successCount = 0;
    let failureCount = 0;

    for (let i = 0; i < fileItems.length; i += batchSize) {
      const batch = fileItems.slice(i, i + batchSize);

      // Process batch concurrently with timeout
      const batchPromises = batch.map(async (item) => {
        try {
          const controller = new AbortController();
          const timeoutId = setTimeout(() => controller.abort(), 10000); // 10 second timeout

          const fileResponse = await fetch(
            `https://gitlab.com/api/v4/projects/${encodeURIComponent(owner + '/' + repo)}/repository/files/${encodeURIComponent(item.path)}?ref=${default_branch}`,
            {
              headers: {
                'Authorization': `Bearer ${token}`,
                'Content-Type': 'application/json'
              },
              signal: controller.signal
            }
          );

          clearTimeout(timeoutId);

          if (fileResponse.ok) {
            const fileInfo = await fileResponse.json() as GitLabFileInfo;
            successCount++;
            return {
              ...item,
              sha: fileInfo.blob_id  // Use blob_id as the SHA
            };
          } else if (fileResponse.status === 404) {
            // File might have been deleted or moved
            console.warn(`File not found (404): ${item.path}`);
            failureCount++;
            return {
              ...item,
              sha: undefined  // No SHA available
            };
          } else {
            console.warn(`Failed to fetch SHA for file ${item.path}: ${fileResponse.status} ${fileResponse.statusText}`);
            failureCount++;
            return {
              ...item,
              sha: undefined  // No SHA available
            };
          }
        } catch (error: any) {
          if (error.name === 'AbortError') {
            console.warn(`Timeout fetching SHA for file ${item.path}`);
          } else {
            console.warn(`Error fetching SHA for file ${item.path}:`, error.message);
          }
          failureCount++;
          return {
            ...item,
            sha: undefined  // No SHA available
          };
        }
      });

      const batchResults = await Promise.all(batchPromises);
      enrichedTree.push(...batchResults);

      // Add small delay between batches to be respectful to the API
      if (i + batchSize < fileItems.length) {
        await new Promise(resolve => setTimeout(resolve, 100));
      }
    }

    console.log(`GitLab: SHA fetching completed. Success: ${successCount}, Failed: ${failureCount}`);
    return enrichedTree;
  }

  private buildGitLabNestedTree(flatTree: Array<GitLabTreeItem & { sha?: string }>): FileTreeNode[] {
    const pathMap: Record<string, any[]> = {};

    flatTree.forEach((item) => {
      const parts = item.path.split("/");
      const fileName = parts.pop()!;
      const parentDir = parts.join("/");

      if (!pathMap[parentDir]) pathMap[parentDir] = [];

      if (item.type === "blob") {
        pathMap[parentDir].push({
          type: "file",
          name: fileName,
          path: item.path,
          sha: item.sha,  // Now properly includes SHA from enriched data
        });
      } else if (item.type === "tree") {
        pathMap[parentDir].push({
          type: "folder",
          name: fileName,
          path: item.path,
          children: [],
        });
      }
    });

    const sortAndAttach = (basePath: string): FileTreeNode[] => {
      const isSpecial = (name: string) => /^[^a-zA-Z0-9]/.test(name);

      const sortedItems = (pathMap[basePath] || []).sort((a, b) => {
        const aSpecial = isSpecial(a.name);
        const bSpecial = isSpecial(b.name);
        if (a.type === b.type) {
          if (aSpecial && !bSpecial) return -1;
          if (!aSpecial && bSpecial) return 1;
          return a.name.localeCompare(b.name);
        }
        return a.type === "folder" ? -1 : 1;
      });

      return sortedItems.map((item) => {
        if (item.type === "folder") {
          const newPath = basePath ? `${basePath}/${item.name}` : item.name;
          item.children = sortAndAttach(newPath);
        }
        return item;
      });
    };

    return sortAndAttach("");
  }

  async getRepositoryList(token: string, page: number = 1, perPage: number = 30): Promise<{
    repositories?: any[];
    error?: boolean;
    message?: string;
    hasMore?: boolean;
    tokenExpiryDate?: Date;
  }> {
    try {
      // Get token expiry details from GitLab API using dedicated endpoint
      let tokenExpiryDate: Date | undefined;
      try {
        const tokenDetailsResponse = await fetch('https://gitlab.com/api/v4/personal_access_tokens/self', {
          headers: {
            'Authorization': `Bearer ${token}`,
            'Content-Type': 'application/json'
          }
        });

        console.log("GitLab token details response status:", tokenDetailsResponse.status);

        if (tokenDetailsResponse.ok) {
          const tokenDetails: any = await tokenDetailsResponse.json();
          console.log("GitLab token details data:", tokenDetails);

          // Extract expiry date from token details
          if (tokenDetails.expires_at) {
            try {
              tokenExpiryDate = new Date(tokenDetails.expires_at);
              console.log("GitLab token expiry date:", tokenExpiryDate);
            } catch (error) {
              console.warn('Failed to parse GitLab token expiry date:', error);
            }
          }
        } else {
          console.log("GitLab token details API failed with status:", tokenDetailsResponse.status);
          // If the specific endpoint fails, we'll continue without expiry date
        }
      } catch (error) {
        console.log("Error fetching GitLab token details:", error);
        // Continue without expiry date if API call fails
      }

      // Fetch repositories from GitLab API
      const response = await fetch(`https://gitlab.com/api/v4/projects?membership=true&page=${page}&per_page=${perPage}&order_by=last_activity_at&sort=desc`, {
        headers: {
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json'
        }
      });

      if (!response.ok) {
        if (response.status === 401) {
          return {
            error: true,
            message: "401 Unauthorized - Invalid or expired GitLab token",
            tokenExpiryDate // Still return expiry date if available
          };
        }
        if (response.status === 403) {
          return {
            error: true,
            message: "403 Forbidden - Token doesn't have permission to access repositories",
            tokenExpiryDate // Still return expiry date if available
          };
        }
        // For other errors (like 500), still return the token expiry date if we have it
        return {
          error: true,
          message: `GitLab API error: ${response.status} ${response.statusText}`,
          tokenExpiryDate // Still return expiry date if available
        };
      }

      const repositories = await response.json() as any[];
      const hasMore = response.headers.get('X-Total-Pages') ?
        Number.parseInt(response.headers.get('X-Total-Pages')!) > page : false;
      const formattedRepositories = repositories.map((repo: any) => ({
        id: repo.id,
        name: repo.name,
        full_name: repo.path_with_namespace,
        description: repo.description,
        visibility: repo.visibility,
        default_branch: repo.default_branch,
        html_url: repo.web_url,
        owner: {
          login: repo.owner?.username || repo.owner?.name,
          avatar_url: repo.namespace?.avatar_url || repo.owner?.avatar_url,
        },
        updated_at: repo.last_activity_at,
        created_at: repo.created_at,
        language: repo.language,
        stargazers_count: repo.star_count,
        forks_count: repo.forks_count
      }));

      return {
        repositories: formattedRepositories,
        hasMore,
        tokenExpiryDate
      };
    } catch (err: any) {
      console.error("Failed to fetch GitLab repositories:", err.message || err);

      if (err.message?.includes('NetworkError') || err.message?.includes('fetch')) {
        return {
          error: true,
          message: "Network error - Unable to connect to GitLab API",
          tokenExpiryDate: undefined
        };
      }

      return {
        error: true,
        message: err.message || "Unknown error fetching GitLab repositories",
        tokenExpiryDate: undefined
      };
    }
  }

  async getFileContent(owner: string, repo: string, path: string, token: string, branch: string): Promise<{
    content?: string;
    error?: boolean;
    message?: string;
  }> {
    try {
      const response = await fetch(
        `https://gitlab.com/api/v4/projects/${encodeURIComponent(owner + '/' + repo)}/repository/files/${encodeURIComponent(path)}?ref=${branch}`,
        {
          headers: {
            'Authorization': `Bearer ${token}`,
            'Content-Type': 'application/json'
          }
        }
      );

      if (!response.ok) {
        throw new Error(`GitLab API error: ${response.status} ${response.statusText}`);
      }

      const data = await response.json() as GitLabFileInfo;
      if (data.content && data.encoding === 'base64') {
        const content = Buffer.from(data.content, 'base64').toString('utf8');
        return { content };
      }

      return {
        error: true,
        message: "Unexpected file content format from GitLab"
      };
    } catch (err: any) {
      console.error("Failed to fetch GitLab file content:", err.message || err);
      return {
        error: true,
        message: err.message || "Error fetching file content from GitLab"
      };
    }
  }
}

// Bitbucket-specific implementation
